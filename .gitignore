# Java / Maven / Spring (server)
# -----------------------------
target/
server/target/

# Maven wrapper binary (kept from server template)
server/.mvn/wrapper/maven-wrapper.jar

# Compiled artifacts
*.class
*.jar
*.war
*.ear


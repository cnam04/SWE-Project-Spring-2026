.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache

# NetBeans
nbproject/private/
nbbuild/
nbdist/
.nb-gradle/

# Keep build dirs under source trees if intentionally created there
!**/src/main/**/target/
!**/src/test/**/target/
!**/src/main/**/build/
!**/src/test/**/build/


